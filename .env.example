# SQL Server connection details
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=document_pipeline
DB_USER=sa
DB_PASSWORD=your_password_here
DB_DRIVER=ODBC Driver 18 for SQL Server

# Pipeline tuning
SIMILARITY_THRESHOLD=0.35
OCR_DPI=300
TESSERACT_LANG=eng

# Feedback tuning
# Amount added to the highest false-positive score to compute a per-type threshold
FEEDBACK_PENALTY=0.05
# Number of false-match records for a single sample page before it is excluded from the corpus
SAMPLE_PAGE_EXCLUSION_COUNT=3

# TF-IDF tuning
# Stop-word removal: set to "english" to strip common English words, or leave blank for none
TFIDF_STOP_WORDS=
# Drop tokens appearing in more than this fraction of a type's sample pages (0.0–1.0)
TFIDF_MAX_DF=1.0
# Drop tokens appearing in fewer than this many of a type's sample pages
TFIDF_MIN_DF=1
# Upper bound of the n-gram range; (1, N) means unigrams through N-grams
TFIDF_NGRAM_MAX=2
# Cap vocabulary size per type; leave blank for unlimited
TFIDF_MAX_FEATURES=
# Warn when a document type has fewer than this many sample pages (IDF signal may be weak)
TFIDF_MIN_TYPE_SAMPLES=3
